# This .gitignore is optimized for Unity development and Unity packages.

# [Unity-specific]
# =========================================================================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Uu]serSettings/

# Asset meta files are REQUIRED for Unity.
# Do NOT ignore these.

# =========================================================================
# [IDE-specific]
# =========================================================================

# [Visual Studio]
.vs/
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.unityproj
*.booproj

# [Visual Studio Code]
.vscode/

# [JetBrains Rider]
.idea/
*.sln.iml

# [Antigravity/Cursor/Generic]
.cursor/
.antigravity/

# =========================================================================
# [OS-specific]
# =========================================================================
.DS_Store
Thumbs.db

# =========================================================================
# [Unity Package specific]
# =========================================================================
# Ignore local lock files if you prefer keeping versions controlled by package.json
# package-lock.json (Keep it if you want deterministic builds, ignore if shared as a reusable package)
